# ==============================================================================
# Awesome Docker Compose - Environment Variables
# 复制此文件为 .env 并修改相应的值
# ==============================================================================

# ============================================================================
# MySQL
# ============================================================================
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=app123456
MYSQL_PORT=3306
PMA_PORT=8080

# ============================================================================
# PostgreSQL
# ============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123456
POSTGRES_DB=app
POSTGRES_PORT=5432
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin123456
PGADMIN_PORT=5050

# ============================================================================
# MongoDB
# ============================================================================
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=root123456
MONGO_DATABASE=admin
MONGO_PORT=27017
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin123456
MONGO_EXPRESS_PORT=8081

# ============================================================================
# Redis
# ============================================================================
REDIS_PORT=6379
REDIS_PASSWORD=redis123456
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin123456
REDIS_COMMANDER_PORT=8081

# ============================================================================
# RabbitMQ
# ============================================================================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123456
RABBITMQ_VHOST=/
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_STOMP_PORT=61613
RABBITMQ_MQTT_PORT=1883

# ============================================================================
# Kafka
